# true = 로그인 없이 로컬만 / false = Google 로그인 + Supabase 동기화 (릴리스)
EXPO_PUBLIC_DEMO_MODE=true

# 공공데이터포털 인증키 (도로교통공단 운전면허 문제은행 15100163)
EXPO_PUBLIC_DATA_GO_KR_SERVICE_KEY=

# Supabase (DEMO_MODE=false 일 때 필수) — docs/RELEASE-KO.md 참고
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
