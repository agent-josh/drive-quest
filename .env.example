# true = 로그인 없이 로컬만 / false = Google 로그인 + Supabase 동기화 (릴리스)
EXPO_PUBLIC_DEMO_MODE=true

# 공공데이터포털 인증키 (도로교통공단 운전면허 문제은행 15100163)
EXPO_PUBLIC_DATA_GO_KR_SERVICE_KEY=

# Expo Go·로컬에서도 Vercel과 같은 1,000문항 (기본: drive-quest-two.vercel.app)
# EXPO_PUBLIC_KOROAD_PROXY_URL=https://drive-quest-two.vercel.app
# 직접 API만 쓰려면: EXPO_PUBLIC_KOROAD_USE_DIRECT=true + 위 서비스키

# Supabase (DEMO_MODE=false 일 때 필수) — docs/RELEASE-KO.md 참고
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
