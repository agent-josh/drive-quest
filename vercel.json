{
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "build": {
    "env": {
      "EXPO_PUBLIC_DEMO_MODE": "true"
    }
  },
  "rewrites": [
    {
      "source": "/((?!_expo/).*)",
      "destination": "/index.html"
    }
  ]
}
